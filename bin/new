#!/usr/bin/env bash
# Generic launcher for container manifests in this repo.
#
# See spec.md for the full contract: required vars, hooks, exported scope.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
MANIFESTS_DIR="${REPO_ROOT}/manifests"
PROFILES_DIR="${REPO_ROOT}/incus/profiles"

log() { printf '%s => %s\n' "$(date -Iseconds)" "$*" >&2; }
export -f log

usage() {

  cat <<EOF
Usage: $(basename "$0") <manifest> <name> [flags]
       $(basename "$0") --list
       $(basename "$0") -h | --help

Launch an Incus container from a manifest in manifests/<manifest>/container.sh.

Required positional args:
  <manifest>                  Directory name under manifests/.
  <name>                      Container name to create.

Flags:
      --ephemeral             Launch with --ephemeral (overrides manifest).
      --no-restart            Skip the post-provision restart.
      --split=<spec>          Split additional paths off into custom storage volumes.
                              <spec> = <path>[:<vol>][,<path>[:<vol>]...].
                              Path must be absolute and not '/'. Volume defaults
                              to <name>-<sanitized-path> (slashes → '-'). Last
                              --split wins. Mutually exclusive with --split-home.
      --split-home[=<vol>]    Sugar for --split=/home[:<vol>].
      --reuse[=<paths>]       Allow reusing pre-existing volumes. No value =
                              reuse all split paths. With value (comma-separated
                              paths), only listed paths may reuse; any other
                              split whose volume already exists errors out.
                              Requires --split or --split-home.
      --pool=<pool>           Incus storage pool for created/probed volumes
                              (default: "default").
      --list                  List available manifests and exit.
  -h, --help                  Show this help and exit.
EOF

}

list_manifests() {
  local m desc
  for m in "${MANIFESTS_DIR}"/*/container.sh; do
    [[ -f "$m" ]] || continue
    desc="$(grep -m1 -E '^DESCRIPTION=' "$m" | sed -E 's/^DESCRIPTION="?([^"]*)"?$/\1/')"
    printf '  %-20s %s\n' "$(basename "$(dirname "$m")")" "${desc:-(no description)}"
  done
}

# ─── Arg parsing ──────────────────────────────────────────────────────────────
EPHEMERAL_OVERRIDE=""
RESTART_OVERRIDE=""
SPLIT_ARG=""
SPLIT_ARG_SET=0
SPLIT_HOME_ARG=""
SPLIT_HOME_SET=0
REUSE_ARG=""
REUSE_SET=0
POOL="default"
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --list)    list_manifests; exit 0 ;;
    --ephemeral) EPHEMERAL_OVERRIDE=1 ;;
    --no-restart) RESTART_OVERRIDE=0 ;;
    --split=*) SPLIT_ARG="${1#--split=}"; SPLIT_ARG_SET=1 ;;
    --split-home) SPLIT_HOME_SET=1; SPLIT_HOME_ARG="" ;;
    --split-home=*) SPLIT_HOME_SET=1; SPLIT_HOME_ARG="${1#--split-home=}" ;;
    --reuse) REUSE_SET=1; REUSE_ARG="" ;;
    --reuse=*) REUSE_SET=1; REUSE_ARG="${1#--reuse=}" ;;
    --pool=*) POOL="${1#--pool=}" ;;
    -*) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
    *) POSITIONAL+=("$1") ;;
  esac
  shift
done

if [[ "${SPLIT_HOME_SET}" == 1 && "${SPLIT_ARG_SET}" == 1 ]]; then
  echo "--split-home and --split are mutually exclusive" >&2; exit 1
fi

if [[ ${#POSITIONAL[@]} -ne 2 ]]; then
  usage >&2
  exit 1
fi

MANIFEST="${POSITIONAL[0]}"
NAME="${POSITIONAL[1]}"
CONTAINER_DIR="${MANIFESTS_DIR}/${MANIFEST}"
MANIFEST_FILE="${CONTAINER_DIR}/container.sh"

[[ -f "${MANIFEST_FILE}" ]] || { echo "Manifest not found: ${MANIFEST_FILE}" >&2; exit 1; }

if incus info "${NAME}" >/dev/null 2>&1; then
  echo "Container '${NAME}' already exists. Delete it first: incus delete ${NAME} --force" >&2
  exit 1
fi

# ─── Source the manifest ──────────────────────────────────────────────────────
# Defaults; manifest may override.
SETUP_SCRIPTS=(setup.sh)
RESTART_AFTER_PROVISION=1
EPHEMERAL=0
CONFIG=()
DEVICES=()

# shellcheck disable=SC1090
source "${MANIFEST_FILE}"

# Validate required vars.
: "${DESCRIPTION:?DESCRIPTION must be set in ${MANIFEST_FILE}}"
: "${IMAGE:?IMAGE must be set in ${MANIFEST_FILE}}"
declare -p PROFILES >/dev/null 2>&1 || { echo "PROFILES must be defined in ${MANIFEST_FILE}" >&2; exit 1; }
declare -p SETUP_SCRIPTS >/dev/null 2>&1 || { echo "SETUP_SCRIPTS must be an array in ${MANIFEST_FILE}" >&2; exit 1; }

# Apply CLI overrides.
[[ -n "${EPHEMERAL_OVERRIDE}" ]] && EPHEMERAL="${EPHEMERAL_OVERRIDE}"
[[ -n "${RESTART_OVERRIDE}" ]] && RESTART_AFTER_PROVISION="${RESTART_OVERRIDE}"

# Resolve + validate setup script paths now so we fail before launch.
# Relative paths resolve against CONTAINER_DIR (so `../<other>/foo.sh`
# lets one manifest reuse another's setup scripts). Basenames must be
# unique — they map 1:1 to /root/<basename> in the container.
SETUP_PATHS=()
declare -A _seen_basenames=()
for s in "${SETUP_SCRIPTS[@]}"; do
  [[ -z "$s" ]] && continue
  sp="$s"
  [[ "$sp" != /* ]] && sp="${CONTAINER_DIR}/${sp}"
  sp="$(realpath -m "$sp")"
  if [[ ! -f "$sp" ]]; then
    echo "Setup script not found: $sp (from SETUP_SCRIPTS entry '$s')" >&2
    exit 1
  fi
  b="$(basename "$sp")"
  if [[ -n "${_seen_basenames[$b]:-}" ]]; then
    echo "Setup script basename collision: '$b' appears more than once in SETUP_SCRIPTS" >&2
    exit 1
  fi
  _seen_basenames[$b]=1
  SETUP_PATHS+=("$sp")
done

# ─── Split-volume specs ───────────────────────────────────────────────────────
# Build SPLIT_SPECS as "path|volume" entries. Default volume name is
# <NAME>-<sanitized-path> (slashes collapsed to '-'). Validated and probed
# now; volumes are created (and conflicts errored) before pre_launch hook.
sanitize_path() {
  local p="$1"
  p="${p#/}"; p="${p%/}"
  p="${p//\//-}"
  printf '%s' "$p"
}

SPLIT_SPECS=()
declare -A _seen_split_paths=()

add_split_entry() {
  local path="$1" vol="$2"
  if [[ "${path}" != /* ]]; then
    echo "--split path must be absolute: '${path}'" >&2; exit 1
  fi
  path="${path%/}"
  if [[ -z "${path}" ]]; then
    echo "cannot split '/' (rootfs is implicit)" >&2; exit 1
  fi
  if [[ -n "${_seen_split_paths[${path}]:-}" ]]; then
    echo "duplicate --split path: '${path}'" >&2; exit 1
  fi
  _seen_split_paths[${path}]=1
  [[ -z "${vol}" ]] && vol="${NAME}-$(sanitize_path "${path}")"
  SPLIT_SPECS+=("${path}|${vol}")
}

if [[ "${SPLIT_HOME_SET}" == 1 ]]; then
  add_split_entry "/home" "${SPLIT_HOME_ARG}"
elif [[ "${SPLIT_ARG_SET}" == 1 ]]; then
  IFS=',' read -ra _split_entries <<< "${SPLIT_ARG}"
  for _e in "${_split_entries[@]}"; do
    [[ -z "${_e}" ]] && continue
    if [[ "${_e}" == *:* ]]; then
      add_split_entry "${_e%%:*}" "${_e#*:}"
    else
      add_split_entry "${_e}" ""
    fi
  done
fi

# Reuse policy: --reuse (no value) = reuse all; --reuse=p1,p2 = only those.
declare -A REUSE_PATHS=()
REUSE_ALL=0
if [[ "${REUSE_SET}" == 1 ]]; then
  if [[ ${#SPLIT_SPECS[@]} -eq 0 ]]; then
    echo "--reuse requires --split or --split-home" >&2; exit 1
  fi
  if [[ -z "${REUSE_ARG}" ]]; then
    REUSE_ALL=1
  else
    IFS=',' read -ra _rps <<< "${REUSE_ARG}"
    for _rp in "${_rps[@]}"; do
      [[ -z "${_rp}" ]] && continue
      _rp="${_rp%/}"
      if [[ -z "${_seen_split_paths[${_rp}]:-}" ]]; then
        echo "--reuse path '${_rp}' is not in --split paths" >&2; exit 1
      fi
      REUSE_PATHS[${_rp}]=1
    done
  fi
fi

# Probe + create volumes. Volumes are attached to the container after launch
# but before setup scripts run (hot-mount via `incus config device add`), so
# /home is the volume by the time useradd runs.
for _spec in "${SPLIT_SPECS[@]}"; do
  _path="${_spec%%|*}"
  _vol="${_spec##*|}"
  _exists=0
  incus storage volume show "${POOL}" "${_vol}" >/dev/null 2>&1 && _exists=1
  _reuse_ok=0
  if [[ "${REUSE_ALL}" == 1 ]] || [[ -n "${REUSE_PATHS[${_path}]:-}" ]]; then
    _reuse_ok=1
  fi
  if [[ "${_exists}" == 1 && "${_reuse_ok}" != 1 ]]; then
    echo "volume '${POOL}/${_vol}' already exists. Pass --reuse or --reuse=${_path} to reuse it." >&2
    exit 1
  fi
  if [[ "${_exists}" == 1 ]]; then
    log "Reusing volume '${POOL}/${_vol}' at ${_path}"
  else
    log "Creating volume '${POOL}/${_vol}' for ${_path}"
    incus storage volume create "${POOL}" "${_vol}" security.shifted=true
  fi
done

export NAME MANIFEST CONTAINER_DIR REPO_ROOT IMAGE

# Hook runner: aborts the launch on non-zero exit.
run_hook() {
  local hook="$1"
  declare -F "$hook" >/dev/null || return 0
  log "Running ${hook}"
  "$hook"
}

# ─── Profile sync + per-profile host prep ─────────────────────────────────────
for p in "${PROFILES[@]}"; do
  pyaml="${PROFILES_DIR}/${p}.yaml"
  [[ -f "${pyaml}" ]] || { echo "Missing profile YAML: ${pyaml}" >&2; exit 1; }
  if ! incus profile show "${p}" >/dev/null 2>&1; then
    log "Creating Incus profile '${p}'"
    incus profile create "${p}"
  fi
  log "Syncing profile '${p}' from ${pyaml}"
  incus profile edit "${p}" < "${pyaml}"

  phost="${PROFILES_DIR}/${p}.host.sh"
  if [[ -f "${phost}" ]]; then
    log "Running host-prep for profile '${p}' (${phost})"
    bash "${phost}"
  fi
done

# ─── Pre-launch hook ──────────────────────────────────────────────────────────
run_hook hook_pre_launch

# ─── Launch ───────────────────────────────────────────────────────────────────
LAUNCH_ARGS=(-p default)
for p in "${PROFILES[@]}"; do LAUNCH_ARGS+=(-p "${p}"); done
for kv in "${CONFIG[@]}"; do LAUNCH_ARGS+=(-c "${kv}"); done
[[ "${EPHEMERAL}" == 1 ]] && LAUNCH_ARGS+=(--ephemeral)

log "Launching '${NAME}' from ${IMAGE}"
incus launch "${IMAGE}" "${NAME}" "${LAUNCH_ARGS[@]}"

# Wait for exec readiness.
log "Waiting for container to be ready"
for _ in $(seq 1 30); do
  incus exec "${NAME}" -- true >/dev/null 2>&1 && break
  sleep 1
done

# ─── Split volumes ────────────────────────────────────────────────────────────
# Attach split-volume disks before setup scripts run. For /home this means
# useradd -m sees the volume (empty on fresh / pre-populated on reuse), not
# the image's /home. Hot-mounted via `incus config device add` — no restart.
for _spec in "${SPLIT_SPECS[@]}"; do
  _path="${_spec%%|*}"
  _vol="${_spec##*|}"
  _devname="split-$(sanitize_path "${_path}")"
  log "Attaching volume '${POOL}/${_vol}' at ${_path}"
  incus config device add "${NAME}" "${_devname}" disk \
    "pool=${POOL}" "source=${_vol}" "path=${_path}"
done

# ─── Devices ──────────────────────────────────────────────────────────────────
for d in "${DEVICES[@]}"; do
  log "Adding device: ${d}"
  # shellcheck disable=SC2086
  incus config device add "${NAME}" $d
done

# ─── Network wait (DNS resolves) ──────────────────────────────────────────────
log "Waiting for container network"
for _ in $(seq 1 60); do
  incus exec "${NAME}" -- getent hosts archlinux.org >/dev/null 2>&1 && break
  sleep 1
done

# ─── /etc/incus-vars ──────────────────────────────────────────────────────────
# Host-known facts that aren't trivially recoverable inside the container.
# Shell-sourceable (`. /etc/incus-vars`); values are %q-quoted so descriptions
# with spaces/specials round-trip safely. IP intentionally omitted — it's
# queryable inside (`ip -4 addr`) and would be wrong pre-restart anyway.
# Build SPLITS as space-separated "<path>:<pool>:<vol>" tokens for the
# container side. Empty when no --split{,-home} was given.
_splits_str=""
for _spec in "${SPLIT_SPECS[@]}"; do
  _splits_str+="${_spec%%|*}:${POOL}:${_spec##*|} "
done
_splits_str="${_splits_str% }"

log "Writing /etc/incus-vars in container"
{
  printf '%s=%q\n' NAME           "${NAME}"
  printf '%s=%q\n' MANIFEST       "${MANIFEST}"
  printf '%s=%q\n' DESCRIPTION    "${DESCRIPTION}"
  printf '%s=%q\n' IMAGE          "${IMAGE}"
  printf '%s=%q\n' PROFILES       "${PROFILES[*]}"
  printf '%s=%q\n' POOL           "${POOL}"
  printf '%s=%q\n' SPLITS         "${_splits_str}"
  printf '%s=%q\n' PROVISIONED_AT "$(date -Iseconds)"
  printf '%s=%q\n' REPO_REV       "$(git -C "${REPO_ROOT}" rev-parse HEAD 2>/dev/null || true)"
} | incus file push - "${NAME}/etc/incus-vars" --mode 0644

# ─── Provision ────────────────────────────────────────────────────────────────
# Paths already resolved + validated above; hooks fire once around the
# whole sequence (not per-script).
if [[ ${#SETUP_PATHS[@]} -gt 0 ]]; then
  run_hook hook_pre_setup
  for sp in "${SETUP_PATHS[@]}"; do
    b="$(basename "$sp")"
    log "Pushing ${sp} and running /root/${b} in container"
    incus file push "$sp" "${NAME}/root/${b}" --mode 0755
    incus exec "${NAME}" -- bash "/root/${b}"
  done
  run_hook hook_post_setup
fi

# ─── Restart ──────────────────────────────────────────────────────────────────
if [[ "${RESTART_AFTER_PROVISION}" == 1 ]]; then
  log "Restarting container"
  incus restart "${NAME}"
fi

# ─── Resolve IP ───────────────────────────────────────────────────────────────
IP=""
log "Waiting for container IP"
for _ in $(seq 1 60); do
  IP="$(incus list "${NAME}" -c 4 --format csv 2>/dev/null | awk '{print $1}')"
  [[ -n "${IP}" ]] && break
  sleep 1
done
export IP

if [[ -z "${IP}" ]]; then
  log "No IP yet. Re-check with: incus list ${NAME}"
fi

# ─── Post-launch hook ─────────────────────────────────────────────────────────
run_hook hook_post_launch
